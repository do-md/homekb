# deps / build
node_modules/
.next/
.next-tauri/
out/
next-env.d.ts
tsconfig.tsbuildinfo

# Desktop build (tauri-build.mjs staging directory)
.tauri-staging/

# Copy-mode packages: zenith/utils source copies are committed (repo must build
# from a fresh clone), but @do-md/core-react must NEVER be committed — it is
# private source; the client consumes the published npm package instead.
client/.packages/@do-md/core-react/

# Rust
engine/target/
client/src-tauri/target/
client/src-tauri/gen/

# Local machine state
.env.local
*.log
.DS_Store
.dev.log
relay.db
relay.db-*

# Relay build output
relay/node/dist/

# Local Claude Code config (agent defs, session state) — not part of the shipped repo
.claude/
CLAUDE.md
AGENTS.md

# Local Codex config (agent defs, session state) — not part of the shipped repo
.codex/
